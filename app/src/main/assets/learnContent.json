    "page": 2,
    "title": "Objectives of Accounting",
    "content": [
      {
        "type": "heading",
        "text": "Objectives of Accounting"
      },
      {
        "type": "paragraph",
        "text": "The primary objective of accounting is to provide useful financial information to stakeholders."
      },
      {
        "type": "table",
        "headers": [
          "Objective",
          "Purpose"
        ],
        "rows": [
          [
            "Record Keeping",
            "Maintain financial records"
          ],
          [
            "Profit Measurement",
            "Determine business performance"
          ],
          [
            "Financial Position",
            "Know assets and liabilities"
          ]
        ]
      },
      {
        "type": "summary",
        "text": "Accounting provides reliable financial information that supports business decisions."
      }
    ]
  }
